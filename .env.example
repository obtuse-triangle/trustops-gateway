# Upstream vLLM server
# Set this to the OpenAI-compatible vLLM endpoint you want to proxy to.
VLLM_BASE_URL=http://localhost:57625

# Gateway runtime
GATEWAY_API_KEY=
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=120
MAX_RESPONSE_BYTES=20971520

# Optional Langfuse tracing
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:56939
