# Upstream vLLM server
# Set this to the OpenAI-compatible vLLM endpoint you want to proxy to.
VLLM_BASE_URL=http://localhost:57625

# Gateway runtime
GATEWAY_API_KEY=dev
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=120
MAX_RESPONSE_BYTES=20971520

# Optional Langfuse tracing
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:56939

# Prompt config
# Kubernetes mounts this at /app/prompt-config.yaml. Local dev uses the example file.
PROMPT_CONFIG_PATH=./prompt-config.example.yaml
